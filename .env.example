# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com/
AZURE_OPENAI_API_KEY=<your-key>
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# Per-task model deployments (swappable for experiments)
TRIAGE_MODEL=gpt-5-4-nano
EXTRACT_MODEL=gpt-5-4
ORCHESTRATE_MODEL=gpt-5-4

# Per-task strategy (swappable)
TRIAGE_STRATEGY=multi-step
EXTRACT_PREPROCESSOR=document-intelligence
ORCHESTRATE_STRATEGY=react

# Document Intelligence
DI_ENDPOINT=https://<your-di>.cognitiveservices.azure.com/
DI_API_KEY=<your-key>

# Performance
MAX_CONCURRENT_REQUESTS=10
LLM_TIMEOUT_SECONDS=25
